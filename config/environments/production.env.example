# Variables específicas del entorno de PRODUCCIÓN
# Los valores reales se gestionan en GCP Secret Manager — NO commitear el .env real

APP_ENV=production
LOG_LEVEL=WARNING
ODOO_LOG_LEVEL=warn
# En producción usar workers (ajustar según CPU disponible)
ODOO_WORKERS=4

# BD en Cloud SQL
POSTGRES_HOST=/cloudsql/${CLOUD_SQL_CONNECTION_NAME}
POSTGRES_PORT=5432

# Habilitar TLS estricto
SMTP_TLS=true

# Sin PgAdmin en producción
# PGADMIN no se despliega en este entorno
