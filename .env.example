# .env.example — Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────
# NUNCA copies este archivo a .env y lo confirmes en el repositorio.
# Copia localmente: cp .env.example .env
# Ajusta cada valor según tu entorno (dev / staging / prod).
# ─────────────────────────────────────────────────────────────────

# ── Entorno general ───────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_SECRET_KEY=change_me_in_production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=comedor_dev
POSTGRES_USER=comedor_user
POSTGRES_PASSWORD=change_me

# ── Odoo 18 ───────────────────────────────────────────────────────
ODOO_HOST=odoo
ODOO_PORT=8069
ODOO_DB=comedor_dev
ODOO_ADMIN_PASSWD=change_me_admin
ODOO_LOG_LEVEL=info              # debug | info | warn | error | critical
# Número máximo de workers de Odoo (0 = modo multithread)
ODOO_WORKERS=0
# Límite de memoria por worker (bytes)
ODOO_LIMIT_MEMORY_HARD=2684354560
ODOO_LIMIT_MEMORY_SOFT=2147483648

# ── Longpolling / WebSocket ───────────────────────────────────────
ODOO_LONGPOLLING_PORT=8072

# ── PgAdmin (opcional, sólo en desarrollo) ────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# ── GCP (producción) ──────────────────────────────────────────────
# Ruta al archivo de credenciales — NUNCA incluir el archivo real
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CREDENTIALS_FILE=/secrets/gcp-credentials.json
# Cloud SQL
CLOUD_SQL_CONNECTION_NAME=your-project:region:instance-name
# Cloud Storage (backups)
GCS_BUCKET_BACKUPS=your-bucket-backups

# ── SMTP / Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=change_me
SMTP_TLS=true

# ── Redis (caché / sesiones, si se usa) ───────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ── Seguridad ─────────────────────────────────────────────────────
# CORS — orígenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:8069,http://localhost:3000
# Ruta de backups cifrados
BACKUP_ENCRYPTION_KEY=change_me_32_char_key
