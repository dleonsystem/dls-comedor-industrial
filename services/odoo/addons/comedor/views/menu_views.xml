<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas del modelo comedor.menu -->

    <!-- Vista: Lista de menús -->
    <record id="view_comedor_menu_tree" model="ir.ui.view">
        <field name="name">comedor.menu.tree</field>
        <field name="model">comedor.menu</field>
        <field name="arch" type="xml">
            <list string="Menús">
                <field name="nombre"/>
                <field name="fecha"/>
                <field name="raciones_disponibles"/>
                <field name="raciones_servidas"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmado'"
                       decoration-muted="state == 'cerrado'"/>
            </list>
        </field>
    </record>

    <!-- Vista: Formulario de menú -->
    <record id="view_comedor_menu_form" model="ir.ui.view">
        <field name="name">comedor.menu.form</field>
        <field name="model">comedor.menu</field>
        <field name="arch" type="xml">
            <form string="Menú del Comedor">
                <header>
                    <button name="action_confirmar" string="Confirmar"
                            type="object" class="btn-primary"
                            invisible="state != 'borrador'"/>
                    <button name="action_cerrar" string="Cerrar servicio"
                            type="object"
                            invisible="state != 'confirmado'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="borrador,confirmado,cerrado"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="fecha"/>
                        </group>
                        <group>
                            <field name="raciones_disponibles"/>
                            <field name="raciones_servidas"/>
                            <field name="activo"/>
                        </group>
                    </group>
                    <field name="descripcion" placeholder="Descripción del menú del día..."/>
                    <notebook>
                        <page string="Raciones registradas">
                            <field name="racion_ids" readonly="1">
                                <list>
                                    <field name="empleado_id"/>
                                    <field name="turno"/>
                                    <field name="fecha_hora"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Acción de ventana para menús -->
    <record id="action_comedor_menu" model="ir.actions.act_window">
        <field name="name">Menús</field>
        <field name="res_model">comedor.menu</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_activo": 1}</field>
    </record>

</odoo>
