<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas del modelo comedor.racion -->

    <!-- Vista: Lista de raciones -->
    <record id="view_comedor_racion_tree" model="ir.ui.view">
        <field name="name">comedor.racion.tree</field>
        <field name="model">comedor.racion</field>
        <field name="arch" type="xml">
            <list string="Raciones">
                <field name="menu_id"/>
                <field name="empleado_id"/>
                <field name="turno"/>
                <field name="fecha_hora"/>
            </list>
        </field>
    </record>

    <!-- Vista: Formulario de ración -->
    <record id="view_comedor_racion_form" model="ir.ui.view">
        <field name="name">comedor.racion.form</field>
        <field name="model">comedor.racion</field>
        <field name="arch" type="xml">
            <form string="Registro de Ración">
                <sheet>
                    <group>
                        <group>
                            <field name="menu_id"/>
                            <field name="empleado_id"/>
                        </group>
                        <group>
                            <field name="turno"/>
                            <field name="fecha_hora"/>
                        </group>
                    </group>
                    <field name="notas" placeholder="Notas adicionales..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de ventana para raciones -->
    <record id="action_comedor_racion" model="ir.actions.act_window">
        <field name="name">Raciones</field>
        <field name="res_model">comedor.racion</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
